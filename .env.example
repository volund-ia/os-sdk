# Chave de API do Volund OS (Configurações → chaves de API). Formato vos_live_...
VOLUND_API_KEY=vos_live_xxx

# Opcional: sobrescreve a URL base (staging/local). Default: produção.
# VOLUND_BASE_URL=https://os.volund.com.br

# Usado pelo agente de exemplo (examples/quickstart.ts)
VOLUND_AGENT_ID=agt_xxx
