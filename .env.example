# Chave de API do Volund OS (Configurações → chaves de API). Formato vos_live_...
VOLUND_API_KEY=vos_live_xxx

# Agente que vai rodar no teste (examples/quickstart.ts). É o UUID do agente,
# SEM prefixo (ex.: 6cb25420-8788-44fd-9461-a7dc4d23a956). Atenção: a API NÃO
# reconhece o formato "agt_<uuid>" — use o UUID puro, senão dá 404 agent_not_found.
VOLUND_AGENT_ID=00000000-0000-0000-0000-000000000000

# URL alvo. Para testar contra o preview do PR, cole a URL do deployment Vercel.
# Em produção, deixe comentado (default: https://os.volund.com.br).
# VOLUND_BASE_URL=https://seu-preview.vercel.app

# Secret do "Protection Bypass for Automation" (seu superior gera na Vercel e
# te envia). Só necessário ao testar contra um preview protegido.
# VERCEL_BYPASS=cole-o-secret-aqui
